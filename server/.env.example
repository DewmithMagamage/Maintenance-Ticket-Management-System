PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bw_maintenance
JWT_SECRET=change-this-to-a-long-random-string-in-production
CLIENT_ORIGIN=http://localhost:5173

# Only if the browser cannot match CLIENT_ORIGIN (e.g. www vs bare domain during testing). Not recommended for public APIs.
# CORS_ORIGIN=*

# Cloud Postgres (Render, Railway, Neon): if you get connection errors or ETIMEDOUT, set:
# DATABASE_SSL=true
# Optional: DATABASE_SSL_REJECT_UNAUTHORIZED=false  (only if your provider uses a cert Node rejects)
# PG_CONNECT_TIMEOUT_MS=15000
